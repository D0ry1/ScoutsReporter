<Window x:Class="ScoutsReporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ScoutsReporter.Views"
        Title="Scouts Reporter" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Icon="fleur-de-lis-marque-purple-png.png"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid TextElement.Foreground="{DynamicResource PrimaryTextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BrandPurpleBrush}" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Scouts Reporter" FontSize="20" FontWeight="Bold"
                                   Foreground="White" />
                        <TextBlock Text="{Binding AppVersion, StringFormat=' v{0}'}" FontSize="12"
                                   Foreground="{DynamicResource BrandHeaderSubtitleBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,2" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="{DynamicResource BrandHeaderSubtitleBrush}" FontSize="12">
                            <Run Text="{Binding GroupName, Mode=OneWay, FallbackValue=''}" />
                            <Run Text=" " />
                            <Run Text="{Binding UserName, Mode=OneWay, StringFormat='({0})', FallbackValue=''}" />
                        </TextBlock>
                        <!-- Unit picker dropdown arrow -->
                        <Button x:Name="UnitPickerButton"
                                Command="{Binding ToggleUnitPickerCommand}"
                                Visibility="{Binding HasMultipleUnits, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,0" Margin="2,0,0,0"
                                VerticalAlignment="Center" Cursor="Hand">
                            <TextBlock Text="&#x25BC;" Foreground="{DynamicResource BrandHeaderSubtitleBrush}" FontSize="10" />
                        </Button>
                    </StackPanel>

                    <!-- Unit picker popup -->
                    <Popup IsOpen="{Binding IsUnitPickerOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=UnitPickerButton}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource PopupBackgroundBrush}"
                                BorderBrush="{DynamicResource BrandPurpleBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="12"
                                Effect="{StaticResource PopupDropShadow}"
                                MinWidth="220">
                            <StackPanel>
                                <TextBlock Text="Select Units" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="All" Command="{Binding SelectAllUnitsCommand}"
                                            Padding="8,2" FontSize="11" Margin="0,0,6,0" />
                                    <Button Content="None" Command="{Binding DeselectAllUnitsCommand}"
                                            Padding="8,2" FontSize="11" />
                                </StackPanel>
                                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AvailableUnits}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          Content="{Binding UnitName}"
                                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                                          FontSize="12" Margin="0,2" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Text="{Binding UnitSelectionSummary}"
                                           FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Login"
                            Command="{Binding LoginCommand}"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Padding="16,8" FontSize="13"
                            FontWeight="SemiBold"
                            Margin="0,0,8,0" />
                    <Button Content="Run All Reports"
                            Command="{Binding RunAllReportsCommand}"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"
                            IsEnabled="{Binding IsRunningAll, Converter={StaticResource InverseBoolConverter}}"
                            Padding="16,8" FontSize="13"
                            FontWeight="SemiBold"
                            Background="{DynamicResource BrandTealBrush}" Foreground="White"
                            Margin="0,0,8,0" />
                    <Button Content="Logout"
                            Command="{Binding LogoutCommand}"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}"
                            Padding="16,8" FontSize="13"
                            FontWeight="SemiBold"
                            Background="{DynamicResource BrandRedBrush}" Foreground="White" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Update banner -->
        <Border Grid.Row="1"
                Background="{DynamicResource DialogInfoBoxBackgroundBrush}"
                BorderBrush="{DynamicResource DialogInfoBoxBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="&#x2139;" FontSize="16"
                           Foreground="{DynamicResource BrandPurpleBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />

                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                           Text="{Binding UpdateBannerText}"
                           Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" />

                <Button Grid.Column="2" Content="Update &amp; Restart"
                        Command="{Binding InstallUpdateCommand}"
                        IsEnabled="{Binding IsInstallingUpdate, Converter={StaticResource InverseBoolConverter}}"
                        Background="{DynamicResource BrandPurpleBrush}" Foreground="White"
                        Padding="12,4" FontSize="12" FontWeight="SemiBold"
                        Margin="8,0" VerticalAlignment="Center" Cursor="Hand" />

                <Button Grid.Column="3" Content="&#x2715;"
                        Command="{Binding DismissUpdateCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource MutedTextBrush}"
                        FontSize="14" Padding="4,0"
                        VerticalAlignment="Center" Cursor="Hand" />
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="2" Margin="8"
                    Background="{DynamicResource WindowBackgroundBrush}">
            <TabItem Header="Dashboard">
                <views:DashboardView DataContext="{Binding Dashboard}" />
            </TabItem>
            <TabItem Header="DBS / Disclosures">
                <views:DbsReportView DataContext="{Binding DbsReport}" />
            </TabItem>
            <TabItem Header="Training">
                <views:TrainingReportView DataContext="{Binding TrainingReport}" />
            </TabItem>
            <TabItem Header="Permits">
                <views:PermitsReportView DataContext="{Binding PermitsReport}" />
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{DynamicResource MainStatusBarBackgroundBrush}" Padding="8,4">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="11"
                           Foreground="{DynamicResource TertiaryTextBrush}"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ToggleButton IsChecked="{Binding Diagnostics.IsEnabled}"
                                  Background="Transparent" BorderThickness="0"
                                  Padding="6,2" Cursor="Hand" Margin="0,0,12,0"
                                  ToolTip="Toggle API diagnostics panel">
                        <TextBlock Text="Diagnostics" FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </ToggleButton>
                    <ToggleButton IsChecked="{Binding IsDarkMode}"
                                  Background="Transparent" BorderThickness="0"
                                  Padding="6,2" Cursor="Hand"
                                  ToolTip="Toggle dark mode">
                        <TextBlock FontSize="11" Foreground="{DynamicResource MutedTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Dark Mode" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                            <Setter Property="Text" Value="Light Mode" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Diagnostics panel -->
        <Border Grid.Row="4"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource MainStatusBarBackgroundBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{Binding Diagnostics.IsPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                MaxHeight="250">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Background="{DynamicResource MainStatusBarBackgroundBrush}" Padding="8,4">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="API Diagnostics" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Diagnostics.EntryCount, StringFormat=' ({0} entries)'}"
                                       FontSize="11" Foreground="{DynamicResource MutedTextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="Copy to Clipboard"
                                    Command="{Binding Diagnostics.CopyToClipboardCommand}"
                                    FontSize="11" Padding="8,2" Margin="0,0,6,0" Cursor="Hand" />
                            <Button Content="Clear"
                                    Command="{Binding Diagnostics.ClearEntriesCommand}"
                                    FontSize="11" Padding="8,2" Cursor="Hand" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Log entries -->
                <ScrollViewer Grid.Row="1" x:Name="DiagnosticScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Background="{DynamicResource WindowBackgroundBrush}">
                    <ItemsControl ItemsSource="{Binding Diagnostics.Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Summary}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{Binding StatusCategory, Converter={StaticResource DiagnosticStatusConverter}}"
                                           Padding="8,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
